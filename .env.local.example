# Copy to .env.local. App degrades gracefully if any of these are missing.

# Sarvam (OCR, STT, LLM, Bulbul TTS). REQUIRED to parse your real uploaded document and to
# read questions aloud with Bulbul. Without it, the app runs in clearly-labelled demo mode.
SARVAM_API_KEY=

# Optional Sarvam model overrides:
#   SARVAM_CHAT_MODEL       - LLM for parse/questions/evaluation. Default sarvam-105b.
#                             Valid hosted IDs: sarvam-105b, sarvam-30b (NOT "sarvam-m").
#   SARVAM_REASONING_EFFORT - none | low | medium | high. Default "none" (reasoning_effort: null,
#                             disables thinking). REQUIRED on the starter tier: with max_tokens
#                             capped at 4096, any reasoning exhausts the budget and returns empty
#                             content. Use low/medium/high only on a tier with token headroom.
#   SARVAM_MAX_TOKENS       - per-request max_tokens ceiling (default 4096 = starter-tier cap).
#                             Raise after upgrading your plan.
#   SARVAM_TTS_MODEL        - Bulbul model for read-aloud (default: bulbul:v2)
#   SARVAM_TTS_SPEAKER      - Bulbul voice (default: anushka)
SARVAM_CHAT_MODEL=
SARVAM_REASONING_EFFORT=
SARVAM_MAX_TOKENS=
SARVAM_TTS_MODEL=
SARVAM_TTS_SPEAKER=

# Cognee - the structural memory backend powering the Career Knowledge Graph (the app's brain).
# When set, every remember() is mirrored into Cognee (add + cognify) and recall() is enriched by
# Cognee's semantic + graph search. When UNSET, a deterministic local graph engine provides the
# SAME remember()/recall()/improve()/forget() semantics, so the whole product works with zero
# credentials (same graceful-degradation posture as DEMO_MODE). Removing this layer removes
# adaptivity, evidence, reality gap, retention decay and the learning roadmap - i.e. the product.
COGNEE_API_URL=
COGNEE_API_KEY=
#   COGNEE_DATASET   - logical dataset name prefix (default "career-memory")
#   COGNEE_DATA_DIR  - where local graph documents are persisted (default ./.career-memory)
COGNEE_DATASET=
COGNEE_DATA_DIR=
