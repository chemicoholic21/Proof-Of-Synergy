# Copy to .env.local. App degrades gracefully if any of these are missing.

# Sarvam (OCR, STT, LLM, Bulbul TTS). REQUIRED to parse your real uploaded document and to
# read questions aloud with Bulbul. Without it, the app runs in clearly-labelled demo mode.
SARVAM_API_KEY=

# Optional Sarvam model overrides:
#   SARVAM_CHAT_MODEL       — LLM for parse/questions/evaluation. Default sarvam-105b.
#                             Valid hosted IDs: sarvam-105b, sarvam-30b (NOT "sarvam-m").
#   SARVAM_REASONING_EFFORT — low | medium | high. Default low (keeps `content` non-empty).
#   SARVAM_TTS_MODEL        — Bulbul model for read-aloud (default: bulbul:v2)
#   SARVAM_TTS_SPEAKER      — Bulbul voice (default: anushka)
SARVAM_CHAT_MODEL=
SARVAM_REASONING_EFFORT=
SARVAM_TTS_MODEL=
SARVAM_TTS_SPEAKER=

# Monad chain (server-side mint/attest). Without these, minting returns a labelled fallback.
MONAD_RPC_URL=https://testnet-rpc.monad.xyz
DEPLOYER_PRIVATE_KEY=

# Filled after running contracts/deploy.sh:
NEXT_PUBLIC_REGISTRY_ADDRESS=
NEXT_PUBLIC_PASSPORT_ADDRESS=
NEXT_PUBLIC_GATE_ADDRESS=
NEXT_PUBLIC_EXPLORER_URL=https://testnet.monadexplorer.com

# Optional: real IPFS pinning. Without it, evidence uses a deterministic mock ipfs:// URI.
PINATA_JWT=
