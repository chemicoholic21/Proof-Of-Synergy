# Copy to .env.local. The app degrades gracefully if any of these are missing:
# without keys it runs with a local conversation partner, heuristic coaching and
# the local skill-graph engine.

# Gemini - the live conversation partner (natural dialogue, follow-ups, pushback).
GEMINI_API_KEY=
#   GEMINI_MODEL - model id (default: gemini-2.0-flash-exp)
GEMINI_MODEL=

# Sarvam AI - natural voice for Indian users: Saarika STT (multilingual, code-mixing),
# Bulbul TTS, and the chat model used for coaching summaries.
SARVAM_API_KEY=
#   SARVAM_CHAT_MODEL       - hosted LLM id: sarvam-105b (default) or sarvam-30b
#   SARVAM_REASONING_EFFORT - none | low | medium | high (default "none"; on the starter
#                             tier any reasoning exhausts the 4096-token budget)
#   SARVAM_MAX_TOKENS       - per-request max_tokens ceiling (default 4096)
#   SARVAM_TTS_MODEL        - Bulbul model for read-aloud (default: bulbul:v2)
#   SARVAM_TTS_SPEAKER      - Bulbul voice (default: anushka)
SARVAM_CHAT_MODEL=
SARVAM_REASONING_EFFORT=
SARVAM_MAX_TOKENS=
SARVAM_TTS_MODEL=
SARVAM_TTS_SPEAKER=

# Cognee - the semantic layer of the Skill Knowledge Graph. When set, every completed
# practice session is mirrored into a per-learner Cognee dataset (add + cognify) and
# recall() is enriched with Cognee's graph-grounded "what should I practice next?".
# When unset, the deterministic local graph engine provides the same
# remember/recall/replay/forget semantics with zero credentials.
COGNEE_API_URL=
COGNEE_API_KEY=
#   COGNEE_DATASET       - dataset name prefix (default "skill-graph")
#   SKILL_GRAPH_DATA_DIR - where local graph documents are persisted (default ./.skill-memory;
#                          use /tmp/skill-memory on serverless)
COGNEE_DATASET=
SKILL_GRAPH_DATA_DIR=

# DEMO_MODE=true substitutes clearly-labelled sample data when a service is unavailable
# (e.g. a demo transcript if STT fails). Never enable in production.
DEMO_MODE=
